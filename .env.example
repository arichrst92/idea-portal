# Root .env — overrides untuk docker-compose
# Copy ke .env dan adjust jika perlu.
# Spec lengkap per-service di backend/.env.example & frontend/.env.example

COMPOSE_PROJECT_NAME=idea-portal

# Override port jika ada conflict di host
# BACKEND_PORT=8000
# FRONTEND_PORT=5173
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
